{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpaykit.dev/schemas/status-envelope.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "invocationId",
    "status",
    "chargeState",
    "version",
    "updatedAt",
    "traceId"
  ],
  "properties": {
    "schemaVersion": { "const": "1" },
    "invocationId": {
      "type": "string",
      "pattern": "^inv_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "status": { "$ref": "invocation-status.json" },
    "chargeState": { "enum": ["NOT_CHARGED", "CHARGED", "SETTLEMENT_UNKNOWN"] },
    "version": { "type": "integer", "minimum": 0 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "traceId": { "type": "string", "pattern": "^trc_[0-9A-HJKMNP-TV-Z]{26}$" }
  }
}
