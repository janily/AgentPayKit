{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpaykit.dev/schemas/release-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["payload", "signature"],
  "properties": {
    "payload": { "type": "object" },
    "signature": {
      "type": "object",
      "required": ["algorithm", "signer", "value"],
      "properties": { "algorithm": { "const": "EIP191" } }
    }
  }
}
