{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpaykit.dev/schemas/error-envelope.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "error"],
  "properties": {
    "schemaVersion": { "const": "1" },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "chargeState", "traceId"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "message": { "type": "string", "minLength": 1 },
        "chargeState": {
          "enum": ["NOT_CHARGED", "CHARGED", "SETTLEMENT_UNKNOWN"]
        },
        "traceId": {
          "type": "string",
          "pattern": "^trc_[0-9A-HJKMNP-TV-Z]{26}$"
        }
      }
    }
  }
}
