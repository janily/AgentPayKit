{
  "schemaVersion": "1",
  "name": "{{skillName}}",
  "clientCompatibility": ">=0.1.0 <1.0.0",
  "install": {
    "sharedClientRequired": true,
    "agents": ["codex", "claude-code"]
  },
  "processors": ["api.example.invalid"],
  "maximumExecutionMs": 30000,
  "files": [
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.json",
    "wrangler.testnet.jsonc",
    "wrangler.mainnet.jsonc",
    "schemas/input.json",
    "schemas/result.json",
    "src/handler.ts",
    "src/success-policy.ts",
    "test/handler.test.ts"
  ],
  "inputSchema": "schemas/input.json",
  "resultSchema": "schemas/result.json"
}
