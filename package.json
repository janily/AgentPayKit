{
  "name": "paybot",
  "version": "1.0.0",
  "description": "Component-driven React web app with X402 micropayments for robot control",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:repository": "vitest run tests/repository",
    "test:e2e": "./e2e-test.sh",
    "test:e2e:dev": "./e2e-test.sh --no-cleanup",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "prettier": "^3.2.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
