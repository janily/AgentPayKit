{
  "name": "agentpaykit",
  "version": "0.1.0",
  "description": "Paid skill runtime and local wallet bridge for coding agents",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test && vitest run tests",
    "test:repository": "vitest run tests/repository",
    "test:e2e": "./e2e-test.sh",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "verify": "node scripts/assert-clean-build.mjs && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "prettier": "^3.2.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
