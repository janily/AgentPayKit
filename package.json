{
  "name": "agentpaykit",
  "version": "0.1.0",
  "description": "Publish and call synchronous x402 paid Skills",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @agentpaykit/client-core build && pnpm --filter @agentpaykit/server build",
    "build": "pnpm -r run build",
    "pretest": "pnpm --filter @agentpaykit/client-core build && pnpm --filter @agentpaykit/server build",
    "test": "pnpm -r run test && vitest run tests/integration tests/repository",
    "test:new-mvp": "vitest run tests/repository/new-workspaces.test.ts tests/integration",
    "format": "prettier --write \"**/*.{ts,tsx,mts,mjs,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mts,mjs,md,json}\"",
    "prelint": "pnpm --filter @agentpaykit/client-core build && pnpm --filter @agentpaykit/server build",
    "lint": "pnpm -r run lint",
    "pretypecheck": "pnpm --filter @agentpaykit/client-core build && pnpm --filter @agentpaykit/server build",
    "typecheck": "pnpm -r run typecheck",
    "verify": "node scripts/assert-clean-build.mjs && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@x402/core": "2.19.0",
    "next": "16.2.10",
    "typescript": "5.9.3",
    "prettier": "3.9.5",
    "vitest": "2.1.9",
    "viem": "2.55.2"
  }
}
