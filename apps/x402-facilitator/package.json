{
  "name": "@paybot/x402-facilitator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "dev:resource": "tsx watch src/example-resource-server.ts",
    "start:resource": "tsx src/example-resource-server.ts",
    "test:client": "tsx src/test-client.ts",
    "build": "tsup src/server.ts --out-dir dist --format esm --target node22",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paybot/x402": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.0.0",
    "viem": "^2.21.53"
  },
  "devDependencies": {
    "@paybot/tsconfig": "workspace:*",
    "tsx": "^4.20.6",
    "tsup": "^8.0.0",
    "typescript": "^5.6.3"
  }
}
