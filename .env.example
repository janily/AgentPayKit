# Optional real-network gates. Default development and CI use fakes.
AGENTPAY_E2E_SEPOLIA=0
AGENTPAY_E2E_MAINNET=0

# Official x402/CDP facilitator credentials.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_FACILITATOR_URL_SEPOLIA=
CDP_FACILITATOR_URL_MAINNET=

# Release-specific payees. Never reuse a testnet Release on mainnet.
SEPOLIA_PAYEE_ADDRESS=
MAINNET_PAYEE_ADDRESS=

# Cloudflare runtime secrets are configured with Wrangler, not committed here.
FACILITATOR_URL=
BLOB_ENCRYPTION_KEY_B64=
RUNTIME_SIGNING_SEED_B64=
RUNTIME_SIGNING_KEY_ID=
RUNTIME_PUBLIC_URL=
BASE_SEPOLIA_RPC_URL=
BASE_MAINNET_RPC_URL=
